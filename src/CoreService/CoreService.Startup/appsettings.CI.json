{
  "ConnectionStrings": {
    "DefaultConnection": "REPLACED_BY_TESTCONTAINERS"
  },
  "Features": {
    "SignalR": false
  },
  "ExternalApis": {
    "Example": "https://api.example.com"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  }
}
