{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.Elasticsearch" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore.HttpLogging": "Information",
        "Microsoft.Hosting.Lifetime": "Information",
        "Yarp": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      },
      {
        "Name": "Elasticsearch",
        "Args": {
          "nodeUris": "http://localhost:9200",
          "indexFormat": "gateway-logs-{0:yyyy.MM.dd}",
          "formatter": "Elastic.CommonSchema.Serilog.EcsTextFormatter, Elastic.CommonSchema.Serilog"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "ApplicationName": "Gateway"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [ "https://localhost:5173", "http://localhost:3000" ]
  },
  "ApplicationSettings": {
    "Secret": "replace-with-shared-secret-at-least-32-chars"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "user-management-cluster",
        "Match": {
          "Path": "/identity/{**catch-all}"
        }
      },
      "admin-route": {
        "ClusterId": "user-management-cluster",
        "AuthorizationPolicy": "permission:roles.manage",
        "Match": {
          "Path": "/admin/{**catch-all}"
        }
      },
      "employees-route": {
        "ClusterId": "user-management-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/employees/{**catch-all}",
          "Methods": [ "GET" ]
        }
      },
      "board-proposal-create-route": {
        "ClusterId": "user-management-cluster",
        "AuthorizationPolicy": "permission:board-proposals.meetings.create",
        "Match": {
          "Path": "/board-proposal-requests",
          "Methods": [ "POST" ]
        }
      },
      "board-proposal-search-route": {
        "ClusterId": "user-management-cluster",
        "AuthorizationPolicy": "permission:board-proposals.read",
        "Match": {
          "Path": "/board-proposal-requests/{id:int}/search",
          "Methods": [ "GET" ]
        }
      },
      "board-proposal-next-step-route": {
        "ClusterId": "user-management-cluster",
        "AuthorizationPolicy": "permission:board-proposals.workflow.next-step",
        "Match": {
          "Path": "/board-proposal-requests/{id:int}/next-step",
          "Methods": [ "POST" ]
        }
      },
      "board-proposal-add-agenda-item-route": {
        "ClusterId": "user-management-cluster",
        "AuthorizationPolicy": "permission:board-proposals.agenda-items.add",
        "Match": {
          "Path": "/board-proposal-requests/{id:int}/agenda-items",
          "Methods": [ "POST" ]
        }
      },
      "board-proposal-set-decision-route": {
        "ClusterId": "user-management-cluster",
        "AuthorizationPolicy": "permission:board-proposals.decisions.register",
        "Match": {
          "Path": "/board-proposal-requests/agenda-items/{agendaItemId:int}/decision",
          "Methods": [ "PUT" ]
        }
      },
      "board-proposal-add-task-route": {
        "ClusterId": "user-management-cluster",
        "AuthorizationPolicy": "permission:board-proposals.tasks.create",
        "Match": {
          "Path": "/board-proposal-requests/agenda-items/{agendaItemId:int}/tasks",
          "Methods": [ "POST" ]
        }
      },
      "board-proposal-add-vote-route": {
        "ClusterId": "user-management-cluster",
        "AuthorizationPolicy": "permission:board-proposals.decisions.register",
        "Match": {
          "Path": "/board-proposal-requests/agenda-items/{agendaItemId:int}/votes",
          "Methods": [ "POST" ]
        }
      },
      "board-proposal-reorder-agenda-items-route": {
        "ClusterId": "user-management-cluster",
        "AuthorizationPolicy": "permission:board-proposals.agenda-items.add",
        "Match": {
          "Path": "/board-proposal-requests/{id:int}/agenda-items/reorder",
          "Methods": [ "PUT" ]
        }
      },
      "board-proposal-reorder-tasks-route": {
        "ClusterId": "user-management-cluster",
        "AuthorizationPolicy": "permission:board-proposals.tasks.create",
        "Match": {
          "Path": "/board-proposal-requests/agenda-items/{agendaItemId:int}/tasks/reorder",
          "Methods": [ "PUT" ]
        }
      },
      "board-proposal-update-task-status-route": {
        "ClusterId": "user-management-cluster",
        "AuthorizationPolicy": "permission:board-proposals.tasks.status.update",
        "Match": {
          "Path": "/board-proposal-requests/tasks/{taskId:int}/status",
          "Methods": [ "PUT" ]
        }
      },
      "board-proposal-read-route": {
        "ClusterId": "user-management-cluster",
        "AuthorizationPolicy": "permission:board-proposals.read",
        "Match": {
          "Path": "/board-proposal-requests/{**catch-all}",
          "Methods": [ "GET" ]
        }
      },
      "attachments-route": {
        "ClusterId": "user-management-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/attachments/{**catch-all}"
        }
      },
      "banking-route": {
        "ClusterId": "banking-operations-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/banking/{**catch-all}"
        }
      },
      "api-route": {
        "ClusterId": "backend-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "{**catch-all}"
        }
      }
    },
    "Clusters": {
      "user-management-cluster": {
        "Destinations": {
          "user-management-1": {
            "Address": "http://localhost:5100/"
          }
        }
      },
      "backend-cluster": {
        "Destinations": {
          "backend-1": {
            "Address": "http://localhost:5200/"
          }
        }
      },
      "banking-operations-cluster": {
        "Destinations": {
          "banking-operations-1": {
            "Address": "http://localhost:5300/"
          }
        }
      }
    }
  }
}
