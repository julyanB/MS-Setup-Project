{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.Elasticsearch" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore.HttpLogging": "Information",
        "Microsoft.Hosting.Lifetime": "Information",
        "Yarp": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      },
      {
        "Name": "Elasticsearch",
        "Args": {
          "nodeUris": "http://localhost:9200",
          "indexFormat": "gateway-logs-{0:yyyy.MM.dd}",
          "formatter": "Elastic.CommonSchema.Serilog.EcsTextFormatter, Elastic.CommonSchema.Serilog"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "ApplicationName": "Gateway"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [ "https://localhost:5173", "http://localhost:3000" ]
  },
  "ApplicationSettings": {
    "Secret": "replace-with-shared-secret-at-least-32-chars"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "user-management-cluster",
        "Match": {
          "Path": "/identity/{**catch-all}"
        }
      },
      "admin-route": {
        "ClusterId": "user-management-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/admin/{**catch-all}"
        }
      },
      "board-proposal-route": {
        "ClusterId": "user-management-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/board-proposal-requests/{**catch-all}"
        }
      },
      "attachments-route": {
        "ClusterId": "user-management-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/attachments/{**catch-all}"
        }
      },
      "banking-route": {
        "ClusterId": "banking-operations-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/banking/{**catch-all}"
        }
      },
      "api-route": {
        "ClusterId": "backend-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "{**catch-all}"
        }
      }
    },
    "Clusters": {
      "user-management-cluster": {
        "Destinations": {
          "user-management-1": {
            "Address": "http://localhost:5100/"
          }
        }
      },
      "backend-cluster": {
        "Destinations": {
          "backend-1": {
            "Address": "http://localhost:5200/"
          }
        }
      },
      "banking-operations-cluster": {
        "Destinations": {
          "banking-operations-1": {
            "Address": "http://localhost:5300/"
          }
        }
      }
    }
  }
}
