{
  "ApplicationSettings": {
    "Secret": "S0M3 M4G1C UN1C0RNS G3N3R4T3D TH1S S3CR3T"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=EmployeeManagementService;Trusted_Connection=True;MultipleActiveResultSets=true;Encrypt=False"
  },
  "Ldap": {
    "Host": "ad.company.local",
    "Port": 636,
    "UseSsl": true,
    "BaseDn": "DC=company,DC=local",
    "Domain": "COMPANY"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.Elasticsearch" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore.HttpLogging": "Information",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      },
      {
        "Name": "Elasticsearch",
        "Args": {
          "nodeUris": "http://localhost:9200",
          "indexFormat": "employee-management-logs-{0:yyyy.MM.dd}",
          "formatter": "Elastic.CommonSchema.Serilog.EcsTextFormatter, Elastic.CommonSchema.Serilog"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "ApplicationName": "EmployeeManagementService"
    }
  },
  "Features": {
    "SignalR": true
  },
  "ExternalApis": {
    "CoreService": "http://localhost:5200/",
    "BankingOperations": "http://localhost:5300/"
  },
  "ConcurrencyConfiguration": {
    "MaxRetries": 3
  },
  "AllowedHosts": "*"
}
